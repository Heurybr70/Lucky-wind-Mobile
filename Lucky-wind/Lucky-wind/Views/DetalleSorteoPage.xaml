<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://xamarin.com/schemas/2014/forms"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:Lucky_wind.ViewModels"
             x:Class="Lucky_wind.Views.DetalleSorteoPage"
             x:Name="DetallePage"
             BackgroundColor="{AppThemeBinding Light=#f6f6f8, Dark=#131022}"
             NavigationPage.HasNavigationBar="False">

    <ScrollView>
        <StackLayout Spacing="0">

            <!-- ── Header ── -->
            <Grid x:Name="HeaderBar"
                  BackgroundColor="{AppThemeBinding Light=#f6f6f8, Dark=#131022}"
                  ColumnDefinitions="Auto, *, Auto"
                  Padding="12,48,12,12">
                <Frame Grid.Column="0"
                       HeightRequest="40" WidthRequest="40" CornerRadius="20"
                       BackgroundColor="Transparent" BorderColor="Transparent"
                       HasShadow="False" Padding="0">
                    <Label Text="🔙" FontSize="22"
                           TextColor="{AppThemeBinding Light=#0f172a, Dark=#f1f5f9}"
                           HorizontalOptions="Center" VerticalOptions="Center">
                        <Label.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnBackTapped"/>
                        </Label.GestureRecognizers>
                    </Label>
                </Frame>
                <Label Grid.Column="1" Text="{Binding Raffle.Name}"
                       FontSize="18" FontAttributes="Bold"
                       TextColor="{AppThemeBinding Light=#0f172a, Dark=#f1f5f9}"
                       VerticalOptions="Center" Margin="8,0"
                       LineBreakMode="TailTruncation"/>
                <!-- Badge de estado -->
                <Frame Grid.Column="2"
                       CornerRadius="10"
                       Padding="10,4"
                       BorderColor="Transparent" HasShadow="False">
                    <Frame.Triggers>
                        <DataTrigger TargetType="Frame" Binding="{Binding IsActive}" Value="True">
                            <Setter Property="BackgroundColor" Value="#d1fae5"/>
                        </DataTrigger>
                        <DataTrigger TargetType="Frame" Binding="{Binding IsFinished}" Value="True">
                            <Setter Property="BackgroundColor" Value="#ede9fe"/>
                        </DataTrigger>
                    </Frame.Triggers>
                    <Label FontSize="11" FontAttributes="Bold" CharacterSpacing="0.5">
                        <Label.Triggers>
                            <DataTrigger TargetType="Label" Binding="{Binding IsActive}" Value="True">
                                <Setter Property="Text" Value="ACTIVO"/>
                                <Setter Property="TextColor" Value="#065f46"/>
                            </DataTrigger>
                            <DataTrigger TargetType="Label" Binding="{Binding IsFinished}" Value="True">
                                <Setter Property="Text" Value="FINALIZADO"/>
                                <Setter Property="TextColor" Value="#5b21b6"/>
                            </DataTrigger>
                        </Label.Triggers>
                    </Label>
                </Frame>
            </Grid>

            <!-- ── Tarjeta de info del sorteo ── -->
            <Frame x:Name="InfoCard"
                   Margin="16,4,16,12"
                   CornerRadius="16"
                   BackgroundColor="{AppThemeBinding Light=White, Dark=#1e1535}"
                   BorderColor="{AppThemeBinding Light=#e2e8f0, Dark=#2d2556}"
                   HasShadow="False" Padding="16">
                <StackLayout Spacing="10">
                    <StackLayout Orientation="Horizontal" Spacing="8">
                        <Label Text="🎰" FontSize="22" VerticalOptions="Center"/>
                        <Label Text="{Binding Raffle.Name}" FontSize="17" FontAttributes="Bold"
                               TextColor="{AppThemeBinding Light=#0f172a, Dark=#f1f5f9}"
                               VerticalOptions="Center"/>
                    </StackLayout>
                    <BoxView HeightRequest="1"
                             Color="{AppThemeBinding Light=#f1f5f9, Dark=#2d2556}"/>
                    <Grid ColumnDefinitions="Auto,*" RowDefinitions="Auto,Auto,Auto" ColumnSpacing="8" RowSpacing="6">
                        <Label Grid.Row="0" Grid.Column="0" Text="🎁 Premio:"
                               FontSize="13" FontAttributes="Bold"
                               TextColor="{AppThemeBinding Light=#475569, Dark=#94a3b8}"/>
                        <Label Grid.Row="0" Grid.Column="1" Text="{Binding Raffle.PrizeDescription}"
                               FontSize="13" TextColor="{AppThemeBinding Light=#0f172a, Dark=#f1f5f9}"/>

                        <Label Grid.Row="1" Grid.Column="0" Text="📅 Fecha:"
                               FontSize="13" FontAttributes="Bold"
                               TextColor="{AppThemeBinding Light=#475569, Dark=#94a3b8}"/>
                        <Label Grid.Row="1" Grid.Column="1" Text="{Binding Raffle.FormattedDate}"
                               FontSize="13" TextColor="{AppThemeBinding Light=#0f172a, Dark=#f1f5f9}"/>

                        <Label Grid.Row="2" Grid.Column="0" Text="👥 Participantes:"
                               FontSize="13" FontAttributes="Bold"
                               TextColor="{AppThemeBinding Light=#475569, Dark=#94a3b8}"/>
                        <Label Grid.Row="2" Grid.Column="1"
                               Text="{Binding Participants.Count, StringFormat='{0} registrados'}"
                               FontSize="13" TextColor="{AppThemeBinding Light=#0f172a, Dark=#f1f5f9}"/>
                    </Grid>
                </StackLayout>
            </Frame>

            <!-- ── Sección Ganador (solo si finalizado) ── -->
            <Frame IsVisible="{Binding IsFinished}"
                   Margin="16,0,16,12"
                   CornerRadius="16"
                   BackgroundColor="{AppThemeBinding Light=#fefce8, Dark=#2d2010}"
                   BorderColor="{AppThemeBinding Light=#fde68a, Dark=#78350f}"
                   HasShadow="False" Padding="16">
                <StackLayout Spacing="8" HorizontalOptions="Center">
                    <Label Text="🏆" FontSize="40" HorizontalOptions="Center"/>
                    <Label Text="¡Ganador!" FontSize="14" FontAttributes="Bold"
                           TextColor="{AppThemeBinding Light=#92400e, Dark=#fbbf24}"
                           HorizontalOptions="Center" CharacterSpacing="1"/>
                    <Label Text="{Binding Raffle.WinnerName}" FontSize="24" FontAttributes="Bold"
                           TextColor="{AppThemeBinding Light=#78350f, Dark=#fde68a}"
                           HorizontalOptions="Center"/>
                    <!-- Compartir resultado -->
                    <Button Text="🎊 Compartir Resultado"
                            BackgroundColor="#f59e0b"
                            TextColor="White"
                            CornerRadius="12"
                            FontAttributes="Bold"
                            HeightRequest="44"
                            Margin="0,4,0,0"
                            Command="{Binding ShareResultCommand}"/>
                </StackLayout>
            </Frame>

            <!-- ── Sección Participantes (solo si activo) ── -->
            <StackLayout IsVisible="{Binding IsActive}" Margin="16,0,16,12" Spacing="10">
                <Label Text="Participantes" FontSize="16" FontAttributes="Bold"
                       TextColor="{AppThemeBinding Light=#0f172a, Dark=#f1f5f9}"/>

                <!-- Añadir participante -->
                <Frame CornerRadius="12"
                       BackgroundColor="{AppThemeBinding Light=White, Dark=#1e1535}"
                       BorderColor="{AppThemeBinding Light=#e2e8f0, Dark=#2d2556}"
                       HasShadow="False" Padding="12,8">
                    <Grid ColumnDefinitions="*, Auto" ColumnSpacing="8">
                        <Entry Grid.Column="0"
                               Placeholder="Nombre del participante"
                               PlaceholderColor="{AppThemeBinding Light=#94a3b8, Dark=#475569}"
                               TextColor="{AppThemeBinding Light=#0f172a, Dark=#f1f5f9}"
                               BackgroundColor="Transparent"
                               Text="{Binding ParticipantInput}"
                               ReturnCommand="{Binding AddParticipantCommand}"
                               ReturnType="Done"/>
                        <Button Grid.Column="1"
                                Text="＋ Agregar"
                                BackgroundColor="#3211d4"
                                TextColor="White"
                                CornerRadius="10"
                                FontSize="13" FontAttributes="Bold"
                                HeightRequest="40"
                                Padding="12,0"
                                Command="{Binding AddParticipantCommand}"/>
                    </Grid>
                </Frame>

                <!-- Indicador de guardado -->
                <StackLayout Orientation="Horizontal" Spacing="6" IsVisible="{Binding IsSaving}">
                    <ActivityIndicator IsRunning="{Binding IsSaving}" Color="#3211d4"
                                       HeightRequest="18" WidthRequest="18"/>
                    <Label Text="Guardando..." FontSize="12"
                           TextColor="{AppThemeBinding Light=#64748b, Dark=#94a3b8}"
                           VerticalOptions="Center"/>
                </StackLayout>

                <!-- Lista de participantes -->
                <StackLayout x:Name="ParticipantsList" Spacing="6" BindableLayout.ItemsSource="{Binding Participants}">
                    <BindableLayout.EmptyView>
                        <Label Text="Aún no hay participantes. ¡Agrega el primero!"
                               FontSize="13" HorizontalOptions="Center"
                               TextColor="{AppThemeBinding Light=#94a3b8, Dark=#475569}"/>
                    </BindableLayout.EmptyView>
                    <BindableLayout.ItemTemplate>
                        <DataTemplate>
                            <Frame CornerRadius="10"
                                   BackgroundColor="{AppThemeBinding Light=White, Dark=#1e1535}"
                                   BorderColor="{AppThemeBinding Light=#e2e8f0, Dark=#2d2556}"
                                   HasShadow="False" Padding="12,10">
                                <Grid ColumnDefinitions="Auto, *, Auto" ColumnSpacing="10">
                                    <!-- Avatar -->
                                    <Frame Grid.Column="0"
                                           HeightRequest="34" WidthRequest="34" CornerRadius="17"
                                           BackgroundColor="#3211d4" BorderColor="Transparent"
                                           HasShadow="False" Padding="0">
                                        <Label Text="👤" FontSize="16"
                                               HorizontalOptions="Center" VerticalOptions="Center"/>
                                    </Frame>
                                    <!-- Nombre -->
                                    <Label Grid.Column="1" Text="{Binding .}"
                                           FontSize="14"
                                           TextColor="{AppThemeBinding Light=#0f172a, Dark=#f1f5f9}"
                                           VerticalOptions="Center"/>
                                    <!-- Botón eliminar -->
                                    <Label Grid.Column="2" Text="✕" FontSize="18"
                                           TextColor="#ef4444" VerticalOptions="Center">
                                        <Label.GestureRecognizers>
                                            <TapGestureRecognizer
                                                Command="{Binding Source={x:Reference DetallePage}, Path=BindingContext.RemoveParticipantCommand}"
                                                CommandParameter="{Binding .}"/>
                                        </Label.GestureRecognizers>
                                    </Label>
                                </Grid>
                            </Frame>
                        </DataTemplate>
                    </BindableLayout.ItemTemplate>
                </StackLayout>
            </StackLayout>

            <!-- ── Lista participantes readonly (para finalizados) ── -->
            <StackLayout IsVisible="{Binding IsFinished}" Margin="16,0,16,12" Spacing="10">
                <Label Text="Participantes" FontSize="16" FontAttributes="Bold"
                       TextColor="{AppThemeBinding Light=#0f172a, Dark=#f1f5f9}"/>
                <StackLayout Spacing="6" BindableLayout.ItemsSource="{Binding Participants}">
                    <BindableLayout.ItemTemplate>
                        <DataTemplate>
                            <Frame CornerRadius="10"
                                   BackgroundColor="{AppThemeBinding Light=White, Dark=#1e1535}"
                                   BorderColor="{AppThemeBinding Light=#e2e8f0, Dark=#2d2556}"
                                   HasShadow="False" Padding="12,10">
                                <Label Text="{Binding .}" FontSize="14"
                                       TextColor="{AppThemeBinding Light=#0f172a, Dark=#f1f5f9}"/>
                            </Frame>
                        </DataTemplate>
                    </BindableLayout.ItemTemplate>
                </StackLayout>
            </StackLayout>

            <!-- ── Botones de acción ── -->
            <StackLayout Margin="16,4,16,32" Spacing="10">
                <!-- Realizar Sorteo (solo activos con participantes) -->
                <Button IsVisible="{Binding IsActive}"
                        Text="🎲 Realizar Sorteo"
                        BackgroundColor="#3211d4"
                        TextColor="White"
                        CornerRadius="16"
                        FontSize="16" FontAttributes="Bold"
                        HeightRequest="52"
                        IsEnabled="{Binding CanRealizarSorteo}"
                        Command="{Binding RealizarSorteoCommand}">
                    <Button.Triggers>
                        <DataTrigger TargetType="Button" Binding="{Binding CanRealizarSorteo}" Value="False">
                            <Setter Property="BackgroundColor" Value="#94a3b8"/>
                        </DataTrigger>
                    </Button.Triggers>
                </Button>

                <!-- Eliminar sorteo (solo activos) -->
                <Button IsVisible="{Binding IsActive}"
                        Text="🗑 Eliminar sorteo"
                        BackgroundColor="Transparent"
                        TextColor="#ef4444"
                        BorderColor="#ef4444"
                        BorderWidth="1.5"
                        CornerRadius="16"
                        FontSize="15" FontAttributes="Bold"
                        HeightRequest="48"
                        Command="{Binding DeleteRaffleCommand}"/>
            </StackLayout>

        </StackLayout>
    </ScrollView>
</ContentPage>
