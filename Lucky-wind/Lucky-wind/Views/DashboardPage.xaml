<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://xamarin.com/schemas/2014/forms"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:Lucky_wind.ViewModels"
             x:Class="Lucky_wind.Views.DashboardPage"
             BackgroundColor="{AppThemeBinding Light=#f6f6f8, Dark=#131022}"
             NavigationPage.HasNavigationBar="False">

    <ScrollView>
        <StackLayout Spacing="0" Padding="28,56,28,40">

            <!-- ── Encabezado ── -->
            <StackLayout x:Name="HeaderStack" Spacing="4" Margin="0,0,0,32">
                <Grid ColumnDefinitions="*, Auto">
                    <Label Text="MENÚ PRINCIPAL"
                           FontSize="22"
                           FontAttributes="Bold"
                           TextColor="{AppThemeBinding Light=#0f172a, Dark=#f1f5f9}"
                           CharacterSpacing="1"
                           VerticalOptions="Center"/>
                    <!-- Botón tema claro/oscuro -->
                    <Frame Grid.Column="1"
                           HeightRequest="40"
                           WidthRequest="40"
                           CornerRadius="20"
                           BackgroundColor="{AppThemeBinding Light=#ede9fc, Dark=#2d1f6e}"
                           BorderColor="Transparent"
                           HasShadow="False"
                           Padding="0">
                        <Frame.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding ToggleThemeCommand}"/>
                        </Frame.GestureRecognizers>
                        <Label Text="{Binding ThemeIcon}"
                               FontSize="18"
                               HorizontalOptions="Center"
                               VerticalOptions="Center"/>
                    </Frame>
                </Grid>
                <StackLayout Orientation="Horizontal" Spacing="6">
                    <Label Text="Bienvenido,"
                           FontSize="14"
                           TextColor="{AppThemeBinding Light=#64748b, Dark=#94a3b8}"/>
                    <Label Text="{Binding UserEmail}"
                           FontSize="14"
                           FontAttributes="Bold"
                           TextColor="#3211d4"/>
                </StackLayout>
            </StackLayout>

            <!-- ── Grid de opciones del menú ── -->
            <Grid ColumnDefinitions="*, *"
                  RowDefinitions="Auto, Auto"
                  ColumnSpacing="14"
                  RowSpacing="14">

                <!-- Registrar Sorteo -->
                <Frame x:Name="Card1" Grid.Row="0" Grid.Column="0"
                       CornerRadius="16"
                       BackgroundColor="{AppThemeBinding Light=White, Dark=#1e1535}"
                       BorderColor="{AppThemeBinding Light=#e2e8f0, Dark=#2d2556}"
                       HasShadow="False"
                       Padding="16">
                    <Frame.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding RegisterSorteoCommand}"/>
                    </Frame.GestureRecognizers>
                    <StackLayout Spacing="12" VerticalOptions="Center" HorizontalOptions="Center">
                        <Frame HeightRequest="52"
                               WidthRequest="52"
                               CornerRadius="26"
                               BackgroundColor="{AppThemeBinding Light=#ede9fc, Dark=#2d1f6e}"
                               BorderColor="Transparent"
                               HasShadow="False"
                               Padding="0"
                               HorizontalOptions="Center">
                            <Label Text="🎰"
                                   FontSize="24"
                                   HorizontalOptions="Center"
                                   VerticalOptions="Center"/>
                        </Frame>
                        <Label Text="Registrar Sorteo"
                               FontSize="13"
                               FontAttributes="Bold"
                               TextColor="{AppThemeBinding Light=#0f172a, Dark=#f1f5f9}"
                               HorizontalOptions="Center"
                               HorizontalTextAlignment="Center"/>
                    </StackLayout>
                </Frame>

                <!-- Ver Historial -->
                <Frame x:Name="Card2" Grid.Row="0" Grid.Column="1"
                       CornerRadius="16"
                       BackgroundColor="{AppThemeBinding Light=White, Dark=#1e1535}"
                       BorderColor="{AppThemeBinding Light=#e2e8f0, Dark=#2d2556}"
                       HasShadow="False"
                       Padding="16">
                    <Frame.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding VerHistorialCommand}"/>
                    </Frame.GestureRecognizers>
                    <StackLayout Spacing="12" VerticalOptions="Center" HorizontalOptions="Center">
                        <Frame HeightRequest="52"
                               WidthRequest="52"
                               CornerRadius="26"
                               BackgroundColor="{AppThemeBinding Light=#ede9fc, Dark=#2d1f6e}"
                               BorderColor="Transparent"
                               HasShadow="False"
                               Padding="0"
                               HorizontalOptions="Center">
                            <Label Text="📋"
                                   FontSize="24"
                                   HorizontalOptions="Center"
                                   VerticalOptions="Center"/>
                        </Frame>
                        <Label Text="Ver Historial"
                               FontSize="13"
                               FontAttributes="Bold"
                               TextColor="{AppThemeBinding Light=#0f172a, Dark=#f1f5f9}"
                               HorizontalOptions="Center"
                               HorizontalTextAlignment="Center"/>
                    </StackLayout>
                </Frame>

                <!-- Análisis Estadístico -->
                <Frame x:Name="Card3" Grid.Row="1" Grid.Column="0"
                       CornerRadius="16"
                       BackgroundColor="{AppThemeBinding Light=White, Dark=#1e1535}"
                       BorderColor="{AppThemeBinding Light=#e2e8f0, Dark=#2d2556}"
                       HasShadow="False"
                       Padding="16">
                    <Frame.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding AnalisisCommand}"/>
                    </Frame.GestureRecognizers>
                    <StackLayout Spacing="12" VerticalOptions="Center" HorizontalOptions="Center">
                        <Frame HeightRequest="52"
                               WidthRequest="52"
                               CornerRadius="26"
                               BackgroundColor="{AppThemeBinding Light=#ede9fc, Dark=#2d1f6e}"
                               BorderColor="Transparent"
                               HasShadow="False"
                               Padding="0"
                               HorizontalOptions="Center">
                            <Label Text="📊"
                                   FontSize="24"
                                   HorizontalOptions="Center"
                                   VerticalOptions="Center"/>
                        </Frame>
                        <Label Text="Análisis Estadístico"
                               FontSize="13"
                               FontAttributes="Bold"
                               TextColor="{AppThemeBinding Light=#0f172a, Dark=#f1f5f9}"
                               HorizontalOptions="Center"
                               HorizontalTextAlignment="Center"/>
                    </StackLayout>
                </Frame>

                <!-- Cerrar Sesión -->
                <Frame x:Name="Card4" Grid.Row="1" Grid.Column="1"
                       CornerRadius="16"
                       BackgroundColor="{AppThemeBinding Light=#fff1f2, Dark=#2d1020}"
                       BorderColor="{AppThemeBinding Light=#fecdd3, Dark=#5c1d2c}"
                       HasShadow="False"
                       Padding="16">
                    <Frame.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding LogoutCommand}"/>
                    </Frame.GestureRecognizers>
                    <StackLayout Spacing="12" VerticalOptions="Center" HorizontalOptions="Center">
                        <Frame HeightRequest="52"
                               WidthRequest="52"
                               CornerRadius="26"
                               BackgroundColor="{AppThemeBinding Light=#fecdd3, Dark=#5c1d2c}"
                               BorderColor="Transparent"
                               HasShadow="False"
                               Padding="0"
                               HorizontalOptions="Center">
                            <Label Text="🚪"
                                   FontSize="24"
                                   HorizontalOptions="Center"
                                   VerticalOptions="Center"/>
                        </Frame>
                        <Label Text="Cerrar Sesión"
                               FontSize="13"
                               FontAttributes="Bold"
                               TextColor="{AppThemeBinding Light=#be123c, Dark=#fb7185}"
                               HorizontalOptions="Center"
                               HorizontalTextAlignment="Center"/>
                    </StackLayout>
                </Frame>

            </Grid>

            <!-- ── Decorador inferior ── -->
            <BoxView Color="#3211d4"
                     Opacity="0.06"
                     HeightRequest="1"
                     Margin="0,40,0,16"/>
            <Label Text="Participa y Gana · v1.0.0"
                   FontSize="11"
                   TextColor="{AppThemeBinding Light=#94a3b8, Dark=#64748b}"
                   HorizontalOptions="Center"/>

        </StackLayout>
    </ScrollView>
</ContentPage>
