<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://xamarin.com/schemas/2014/forms"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:Lucky_wind.ViewModels"
             x:Class="Lucky_wind.Views.SplashPage"
             BackgroundColor="#f6f6f8"
             NavigationPage.HasNavigationBar="False">

    <!-- El BindingContext se asigna en el constructor del code‑behind -->

    <Grid RowDefinitions="*,Auto,Auto">

        <!-- ── Sección central de branding ── -->
        <StackLayout Grid.Row="0"
                     VerticalOptions="Center"
                     HorizontalOptions="Center"
                     Spacing="16"
                     Padding="32,0">

            <!-- Contenedor circular del logo -->
            <Frame x:Name="LogoFrame"
                   HeightRequest="128"
                   WidthRequest="128"
                   CornerRadius="64"
                   BackgroundColor="#ede9fc"
                   BorderColor="#c4b5fd"
                   IsClippedToBounds="True"
                   HorizontalOptions="Center"
                   HasShadow="False"
                   Padding="0">
                <Label Text="★"
                       FontSize="56"
                       HorizontalOptions="Center"
                       VerticalOptions="Center"
                       TextColor="#3211d4"/>
            </Frame>

            <!-- Título principal -->
            <Label Text="Lucky-Win"
                   FontSize="40"
                   FontAttributes="Bold"
                   HorizontalOptions="Center"
                   TextColor="#0f172a"
                   Margin="0,8,0,0"/>

            <!-- Línea decorativa -->
            <BoxView Color="#3211d4"
                     Opacity="0.3"
                     HeightRequest="1"
                     WidthRequest="48"
                     HorizontalOptions="Center"
                     Margin="0,4"/>

            <!-- Tagline -->
            <Label Text="Simple. Clean. Elegant."
                   FontSize="13"
                   HorizontalOptions="Center"
                   TextColor="#64748b"
                   FontAttributes="Italic"/>
        </StackLayout>

        <!-- ── Versión ── -->
        <Label Grid.Row="1"
               Text="Version 1.0.0"
               FontSize="10"
               HorizontalOptions="Center"
               TextColor="#94a3b8"
               Margin="0,0,0,12"/>

        <!-- ── Botón "Comenzar" con estilo outlined ── -->
        <Frame Grid.Row="2"
               Margin="32,0,32,48"
               CornerRadius="8"
               BorderColor="#c4b5fd"
               BackgroundColor="Transparent"
               HasShadow="False"
               Padding="0">
            <Button Text="Comenzar  →"
                    BackgroundColor="Transparent"
                    TextColor="#0f172a"
                    FontSize="15"
                    HeightRequest="52"
                    Command="{Binding StartCommand}"/>
        </Frame>

    </Grid>
</ContentPage>
