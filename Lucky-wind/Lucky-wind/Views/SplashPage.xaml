<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://xamarin.com/schemas/2014/forms"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Lucky_wind.Views.SplashPage"
             BackgroundColor="{AppThemeBinding Light=#f6f6f8, Dark=#131022}"
             NavigationPage.HasNavigationBar="False">

    <Grid RowDefinitions="*,Auto,Auto">

        <!-- ── Sección central de branding ── -->
        <StackLayout Grid.Row="0"
                     VerticalOptions="Center"
                     HorizontalOptions="Center"
                     Spacing="16"
                     Padding="32,0">

            <!-- Contenedor circular del logo -->
            <Frame x:Name="LogoFrame"
                   HeightRequest="128"
                   WidthRequest="128"
                   CornerRadius="64"
                   BackgroundColor="{AppThemeBinding Light=#ede9fc, Dark=#2d1f6e}"
                   BorderColor="{AppThemeBinding Light=#c4b5fd, Dark=#4c3bbf}"
                   IsClippedToBounds="True"
                   HorizontalOptions="Center"
                   HasShadow="False"
                   Padding="0">
                <Label Text="🏆"
                       FontSize="52"
                       HorizontalOptions="Center"
                       VerticalOptions="Center"/>
            </Frame>

            <!-- Título principal -->
            <Label x:Name="TitleLabel"
                   Text="Participa y Gana"
                   FontSize="36"
                   FontAttributes="Bold"
                   HorizontalOptions="Center"
                   TextColor="{AppThemeBinding Light=#0f172a, Dark=#f1f5f9}"
                   Margin="0,8,0,0"/>

            <!-- Línea decorativa -->
            <BoxView x:Name="DividerBox"
                     Color="#3211d4"
                     Opacity="0.4"
                     HeightRequest="2"
                     WidthRequest="56"
                     HorizontalOptions="Center"
                     CornerRadius="1"
                     Margin="0,4"/>

            <!-- Tagline -->
            <Label x:Name="TaglineLabel"
                   Text="Tu suerte comienza aquí."
                   FontSize="14"
                   HorizontalOptions="Center"
                   TextColor="{AppThemeBinding Light=#64748b, Dark=#94a3b8}"
                   FontAttributes="Italic"/>
        </StackLayout>

        <!-- ── Versión ── -->
        <Label x:Name="VersionLabel"
               Grid.Row="1"
               Text="Versión 1.0.0"
               FontSize="10"
               HorizontalOptions="Center"
               TextColor="{AppThemeBinding Light=#94a3b8, Dark=#64748b}"
               Margin="0,0,0,12"/>

        <!-- ── Botón "Comenzar" ── -->
        <Frame x:Name="StartFrame"
               Grid.Row="2"
               Margin="32,0,32,48"
               CornerRadius="8"
               BorderColor="{AppThemeBinding Light=#c4b5fd, Dark=#4c3bbf}"
               BackgroundColor="Transparent"
               HasShadow="False"
               Padding="0">
            <Button Text="Comenzar 🤑"
                    BackgroundColor="Transparent"
                    TextColor="{AppThemeBinding Light=#0f172a, Dark=#f1f5f9}"
                    FontSize="15"
                    HeightRequest="52"
                    Command="{Binding StartCommand}"/>
        </Frame>

    </Grid>
</ContentPage>
