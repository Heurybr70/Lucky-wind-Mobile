root = true

# Todos los archivos: UTF-8 sin BOM, LF, trim trailing spaces
[*]
charset = utf-8
end_of_line = lf
trim_trailing_whitespace = true
insert_final_newline = true

# XML / Android resources: CRÍTICO — aapt2 rechaza BOM en archivos XML
# charset = utf-8 (sin BOM) es obligatorio para que aapt2 compile correctamente
[*.xml]
charset = utf-8
indent_style = space
indent_size = 4

# C# / XAML: también sin BOM para consistencia
[*.{cs,xaml}]
charset = utf-8
indent_style = space
indent_size = 4
